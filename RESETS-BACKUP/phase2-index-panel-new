scoreEngine: {
  weights: {
    time: 1.0,
    itemCommon: 1,
    itemUncommon: 3,
    itemRare: 5,
    itemEpic: 10,
    itemLegendary: 20
  },

  computeScore({ timeTaken, itemsMeta }) {
    const w = this.weights;

    // TIME SCORE (simple placeholder)
    const timeScore = Math.max(0, Math.floor((600 - timeTaken) * w.time));

    // ITEM SCORE
    let itemScore = 0;
    const rarityBreakdown = {
      common: 0,
      uncommon: 0,
      rare: 0,
      epic: 0,
      legendary: 0
    };

    itemsMeta.forEach(meta => {
      const r = (meta.rarity || "common").toLowerCase();
      rarityBreakdown[r] = (rarityBreakdown[r] || 0) + 1;

      switch (r) {
        case "legendary": itemScore += w.itemLegendary; break;
        case "epic": itemScore += w.itemEpic; break;
        case "rare": itemScore += w.itemRare; break;
        case "uncommon": itemScore += w.itemUncommon; break;
        default: itemScore += w.itemCommon; break;
      }
    });

    const totalScore = timeScore + itemScore;

    return {
      totalScore,
      breakdown: {
        timeScore,
        itemScore,
        rarityBreakdown
      }
    };
  }
}
