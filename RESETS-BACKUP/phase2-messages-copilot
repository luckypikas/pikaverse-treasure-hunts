    const raw = localStorage.getItem(this.STORAGE_KEY);
    const parsed = this.safeParse(raw, {});

    const hunt = Array.isArray(parsed)
      ? parsed.find(h => h && h.id === huntId)
      : parsed[huntId];

    return this.normalizeHunt(hunt);
  },

  // ---------------------------------------------
  // NORMALIZE HUNT (LENIENT, BACKWARD-COMPATIBLE)
  // ---------------------------------------------
  normalizeHunt(h) {
    if (!h || typeof h !== "object") return null;

    const base = { ...h };

    base.id = base.id || "";
    base.title = base.title || base.id || "Untitled Hunt";
    base.description = base.description || "";
    base.difficulty = base.difficulty || "Standard";

    // Items: preserve shape for existing hunts
    if (!base.items || typeof base.items !== "object") {
      base.items = {};
    }

    // Nodes: must be array (engine normalizes each node)
    if (!Array.isArray(base.nodes)) {
      base.nodes = [];
    }

    // Metadata: optional
    base.metadata = base.metadata && typeof base.metadata === "object"
      ? base.metadata
      : { timerSeconds: 0, keyRequirements: [] };

    // Persistence mode
    base.statePersistence =
      base.statePersistence === "persistent" ? "persistent" : "session";

    return base;
