            : r === "epic"
            ? "epic"
            : r === "rare"
            ? "rare"
            : r === "uncommon"
            ? "uncommon"
            : "common";

        rarityBreakdown[normalized] = (rarityBreakdown[normalized] || 0) + 1;

        switch (normalized) {
          case "legendary":
            itemScore += w.itemLegendary ?? 0;
            break;
          case "epic":
            itemScore += w.itemEpic ?? 0;
            break;
          case "rare":
            itemScore += w.itemRare ?? 0;
            break;
          case "uncommon":
            itemScore += w.itemUncommon ?? 0;
            break;
          default:
            itemScore += w.itemCommon ?? 0;
            break;
