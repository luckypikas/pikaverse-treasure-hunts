    popup.appendChild(nameEl);

    if (meta.description) {
      const descEl = document.createElement("div");
      descEl.textContent = meta.description;
      descEl.style.opacity = "0.8";
      descEl.style.fontSize = "12px";
      popup.appendChild(descEl);
    }

    return popup;
  },

