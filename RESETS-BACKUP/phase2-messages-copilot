    this.musicStarted = true;

    this.music.play().catch(() => {});
  },

  registerFirstInteraction() {
    if (this.firstInteraction) return;
    this.firstInteraction = true;
    this.startMusicIfNeeded();
  },

  // --------------------------------------------------
  // 🧠 STATE SYSTEM HELPERS (LAYER 1)
  // --------------------------------------------------

  _getStateStorageKey() {
    const huntId = this.hunt && this.hunt.id;
    if (!huntId) return null;
    return `pikaverse_state_${huntId}`;
  },

  _getStatePersistenceMode() {
    const mode = this.hunt && this.hunt.statePersistence;
    if (mode === "persistent" || mode === "session") {
      return mode;
    }

    console.warn(
      "⚠️ Hunt missing valid statePersistence — defaulting to 'session'. " +
      "Set hunt.statePersistence to 'persistent' or 'session'."
    );
    return "session";
  },

  loadStateForHunt() {
    const mode = this._getStatePersistenceMode();
    const key = this._getStateStorageKey();

    if (mode === "persistent" && key) {
      try {
        const raw = localStorage.getItem(key);
        this.state = raw ? JSON.parse(raw) || {} : {};
      } catch {
        this.state = {};
      }
    } else {
      this.state = {};
      if (key) {
        try {
          localStorage.removeItem(key);
        } catch {
          // ignore
        }
      }
    }
  },

  saveStateForHunt() {
    const mode = this._getStatePersistenceMode();
    const key = this._getStateStorageKey();

    if (mode === "persistent" && key) {
      try {
        localStorage.setItem(key, JSON.stringify(this.state || {}));
      } catch {
        // ignore
      }
    }
  },

  // session mode: state is in-memory only
  setState(key, value) {
    if (!key) return;
    this.state = this.state || {};
    this.state[key] = value;
    this.saveStateForHunt();
  },

  getState(key) {
    if (!key) return undefined;
    return this.state ? this.state[key] : undefined;
  },

  // --------------------------------------------------
  // 🧠 INVENTORY RUNTIME API
  // --------------------------------------------------

  getInventory() {
    const inv = this.getState("inventory");
    return Array.isArray(inv) ? inv : [];
  },

  hasItem(itemId) {
    if (!itemId) return false;
    const inv = this.getInventory();
    return inv.includes(itemId);
  },

  hasAllItems(items) {
    if (!Array.isArray(items) || items.length === 0) return true;
    const inv = this.getInventory();
    return items.every(i => inv.includes(i));
  },

  addItem(itemId) {
    if (!itemId) return;
    const inv = this.getInventory();
    if (!inv.includes(itemId)) {
      const next = inv.concat(itemId);
      this.setState("inventory", next);
      this.updateInventoryUI();
      this.showRewardPopup([itemId]);
    }
  },

  removeItem(itemId) {
    if (!itemId) return;
    const inv = this.getInventory();
    const next = inv.filter(i => i !== itemId);
    this.setState("inventory", next);
    this.updateInventoryUI();
  },

  // --------------------------------------------------
  // 🧠 ITEM METADATA HELPERS
  // --------------------------------------------------

  getItemMetadata(itemId) {
    const rawItems = this.hunt?.items;

    const itemsArray = Array.isArray(rawItems)
      ? rawItems
      : rawItems && typeof rawItems === "object"
      ? Object.values(rawItems)
      : [];

    const raw = itemsArray.find(
      it => it && (it.id === itemId || it.itemId === itemId)
    );

    const meta = raw || {};
    const name = meta.name || itemId;
    const icon = meta.icon || meta.iconUrl || "";
    const rarity = meta.rarity || "common";
    const description = meta.description || "";

    return {
      id: itemId,
      name,
      icon,
      rarity,
      description
    };
  },

  getRarityColor(rarity) {
    const r = (rarity || "").toLowerCase();
    switch (r) {
      case "legendary":
        return "#ffb74d";
      case "epic":
        return "#ba68c8";
      case "rare":
        return "#4fc3f7";
      case "uncommon":
        return "#81c784";
      default:
        return "#e0e0e0";
    }
  },

