let hunts = [];
let results = [];
let selectedHunt = null;

let searchQuery = "";
let filterMode = "all";

// -----------------------------
// SAFE PARSE
// -----------------------------
function safeParse(json, fallback) {
  try {
    const parsed = JSON.parse(json);
    return parsed && typeof parsed === "object" ? parsed : fallback;
  } catch {
    return fallback;
  }
}

// -----------------------------
// LOAD DATA
// -----------------------------
function loadData() {
  const h = localStorage.getItem("pikaverse_hunts_v4");
  const r = localStorage.getItem("pikaverse_results");

  const parsedHunts = safeParse(h, {});
  hunts = Array.isArray(parsedHunts)
    ? parsedHunts
    : Object.values(parsedHunts || {});

  const parsedResults = safeParse(r, []);
  results = Array.isArray(parsedResults) ? parsedResults : [];

  injectControls();
  renderList();
}

// -----------------------------
// UI CONTROLS
// -----------------------------
function injectControls() {
  const left = document.getElementById("hub-left");
  if (!left || document.getElementById("hub-controls")) return;

  const wrapper = document.createElement("div");
  wrapper.id = "hub-controls";
  wrapper.style.padding = "10px";
  wrapper.style.borderBottom = "1px solid #1f2230";

  wrapper.innerHTML = `
    <button id="createHuntBtn" style="width:100%;margin-bottom:8px;">
      + Create New Hunt
    </button>

    <input
      id="huntSearch"
      placeholder="Search hunts..."
      style="width:100%;margin-bottom:6px;"
    />

    <select id="huntFilter" style="width:100%;">
      <option value="all">All Hunts</option>
      <option value="completed">Completed</option>
      <option value="not_started">Not Started</option>
    </select>
  `;

  left.insertBefore(wrapper, document.getElementById("hunt-list"));

  document.getElementById("createHuntBtn").onclick = createNewHunt;

  document.getElementById("huntSearch").oninput = (e) => {
    searchQuery = (e.target.value || "").toLowerCase();
    renderList();
  };

  document.getElementById("huntFilter").onchange = (e) => {
    filterMode = e.target.value;
    renderList();
  };
}

// -----------------------------
// CREATE NEW HUNT (CORE FEATURE)
// -----------------------------
function createNewHunt() {
  const raw = safeParse(localStorage.getItem("pikaverse_hunts_v4"), {});

  const id = "hunt_" + Date.now();

  const newHunt = {
    id,
    title: "New Treasure Hunt",
    description: "Start building your adventure...",
    difficulty: "Standard",

    statePersistence: "session",

    metadata: {
      timerSeconds: 0,
      keyRequirements: []
    },

    items: {},

    nodes: [
      {
        id: "node_001",
        type: "start",
        title: "Start Node",
        body: "Begin your adventure",
        nextNodeId: null,
        map: { x: 120, y: 120 },
        puzzle: null,
        advanced: {},

        timerSeconds: 0,
        onEnter: {},
        onExit: {},
        setState: null,
        increment: null,
        addToInventory: null,
        removeFromInventory: null,
        conditions: [],
        requires: [],
        failNodeId: null
      }
    ]
  };

  raw[id] = newHunt;

  localStorage.setItem("pikaverse_hunts_v4", JSON.stringify(raw));

  // 🔗 handoff to editor
  localStorage.setItem("pikaverse_hunt_id", id);

  window.location.href = "admin.html";
}

// -----------------------------
// STATUS + RESULTS
// -----------------------------
function getBestResult(huntId) {
  const filtered = results.filter(r => r && r.huntId === huntId);
  if (!filtered.length) return null;

  return filtered.reduce((best, curr) => {
    return (curr?.score?.totalScore || 0) >
      (best?.score?.totalScore || 0)
      ? curr
      : best;
  }, filtered[0]);
}

function getCompletionStatus(huntId) {
  const attempts = results.filter(r => r && r.huntId === huntId).length;

  return attempts > 0
    ? { label: "✓ Completed", className: "status-completed" }
    : { label: "● Not Started", className: "status-not-started" };
}

// -----------------------------
// LIST
// -----------------------------
function renderList() {
  const list = document.getElementById("hunt-list");
  if (!list) return;

  list.innerHTML = "";

  let filtered = [...hunts];

  if (searchQuery) {
    filtered = filtered.filter(h =>
      (h.title || h.id || "").toLowerCase().includes(searchQuery)
    );
  }

  if (filterMode !== "all") {
    filtered = filtered.filter(h => {
      const attempts = results.filter(r => r && r.huntId === h.id).length;
      return filterMode === "completed" ? attempts > 0 : attempts === 0;
    });
  }

  filtered.forEach(hunt => {
    if (!hunt || !hunt.id) return;

    const div = document.createElement("div");
    div.className = "hunt-item";

    if (selectedHunt && selectedHunt.id === hunt.id) {
      div.classList.add("active");
    }

    const status = getCompletionStatus(hunt.id);

    div.innerHTML = `
      <div><strong>${hunt.title || hunt.id}</strong></div>
      <div style="opacity:0.6;font-size:12px">
        ${hunt.difficulty || "Standard"}
      </div>
      <div class="status-badge ${status.className}">
        ${status.label}
      </div>
    `;

    div.onclick = () => selectHunt(hunt);

    list.appendChild(div);
  });
}

// -----------------------------
// SELECT
// -----------------------------
function selectHunt(hunt) {
  selectedHunt = hunt;
  renderList();
  renderDetails(hunt);
}

// -----------------------------
// DETAILS
// -----------------------------
function renderDetails(hunt) {
  const container = document.getElementById("hunt-details");
  if (!container || !hunt) return;

  const best = getBestResult(hunt.id);
  const attempts = results.filter(r => r && r.huntId === hunt.id).length;

  container.innerHTML = `
    <div class="detail-title">${hunt.title}</div>
    <div class="meta">${hunt.description}</div>

    <div class="stat">Difficulty: ${hunt.difficulty || "Standard"}</div>
