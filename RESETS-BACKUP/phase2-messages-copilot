function loadData() {
  const h = localStorage.getItem("pikaverse_hunts_v4");
  const r = localStorage.getItem("pikaverse_results");

  const parsedHunts = safeParse(h, {});
  hunts = Array.isArray(parsedHunts) ? parsedHunts : Object.values(parsedHunts);

  results = Array.isArray(safeParse(r, [])) ? safeParse(r, []) : [];

  renderList();
}

// -----------------------------
