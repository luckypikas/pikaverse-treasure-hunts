    }

    if (listEl) {
      listEl.innerHTML = "";
      if (inv.length === 0) {
        const empty = document.createElement("div");
        empty.textContent = "No items yet.";
        empty.style.opacity = "0.7";
        listEl.appendChild(empty);
      } else {
        inv.forEach(itemId => {
          const meta = this.getItemMetadata(itemId);
          const rarityColor = this.getRarityColor(meta.rarity);

          const row = document.createElement("div");
          row.style.display = "flex";
          row.style.alignItems = "center";
          row.style.gap = "6px";
          row.style.padding = "4px 0";
          row.style.borderBottom = "1px solid rgba(255,255,255,0.06)";

          if (meta.icon) {
            const img = document.createElement("img");
            img.src = meta.icon;
            img.alt = meta.name;
            img.style.width = "20px";
            img.style.height = "20px";
            img.style.objectFit = "contain";
            img.style.flexShrink = "0";
            row.appendChild(img);
          }

          const textWrap = document.createElement("div");
          textWrap.style.display = "flex";
          textWrap.style.flexDirection = "column";
          textWrap.style.alignItems = "flex-start";

          const nameEl = document.createElement("span");
          nameEl.textContent = meta.name;
          nameEl.style.fontSize = "12px";

          const rarityEl = document.createElement("span");
          rarityEl.textContent = meta.rarity || "common";
          rarityEl.style.fontSize = "10px";
          rarityEl.style.opacity = "0.8";
          rarityEl.style.color = rarityColor;

          textWrap.appendChild(nameEl);
          textWrap.appendChild(rarityEl);

          row.appendChild(textWrap);

          if (meta.description) {
