  loadHunt(huntData) {
    this.hunt = huntData || {};
    this.nodeMap = {};

    if (Array.isArray(huntData?.nodes)) {
      const normalizedNodes = huntData.nodes
        .map(normalizeNode)
        .filter(n => n && n.id);

      normalizedNodes.forEach(node => {
        this.nodeMap[node.id] = node;
      });

      this.hunt.nodes = normalizedNodes;
    }

    this.loadStateForHunt();
  },

  start() {
    this.nodeContainer = document.getElementById("game-node-container");
    if (!this.nodeContainer) return;

    this.loadVolume();
    this.createAudioControls();
    this.initMusic();
    this.createInventoryUI();
    this.updateInventoryUI();

    // CENTRALIZED, SAFE HUNT LOADING PRIORITY
    // 1) Admin Play/Test override: pikaverse_test_hunt
    // 2) Hub selection: pikaverse_hunt_id via adapter
    // 3) Legacy full-hunt blob: pikaverse_hunt
    // 4) Fallback: existing this.hunt (if already set)

    let active = null;

    // 1) TEST HUNT OVERRIDE
    try {
      const storedTest = localStorage.getItem("pikaverse_test_hunt");
      if (storedTest) {
        const parsed = JSON.parse(storedTest);
        if (parsed && parsed.hunt) {
          active = parsed.hunt;
          console.log("🧪 Using TEST hunt override");
        }
        localStorage.removeItem("pikaverse_test_hunt");
      }
    } catch (e) {
      console.warn("Failed to parse test hunt override", e);
    }

    // 2) HUB SELECTION VIA ADAPTER
    if (!active) {
      const huntId = localStorage.getItem("pikaverse_hunt_id");
      if (huntId) {
        try {
          const fromAdapter = loadActiveHunt(huntId);
          if (fromAdapter) {
            active = fromAdapter;
            console.log("🎮 Using hunt from adapter by id:", huntId);
          }
        } catch (e) {
          console.warn("Failed to load hunt from adapter", e);
        }
      }
    }

    // 3) LEGACY FULL-HUNT BLOB
    if (!active) {
      try {
        const storedLive = localStorage.getItem("pikaverse_hunt");
        if (storedLive) {
          const parsed = JSON.parse(storedLive);
          if (parsed && typeof parsed === "object") {
            active = parsed;
            console.log("📦 Using legacy LIVE hunt blob");
          }
        }
      } catch (e) {
        console.warn("Failed to parse legacy live hunt", e);
      }
