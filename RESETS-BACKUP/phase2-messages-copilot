  applyVolumeToAll() {
    const volume = this.isMuted ? 0 : this.masterVolume;

    Object.values(this.sounds || {}).forEach(s => {
      if (s) s.volume = volume;
    });

    if (this.music) {
      this.music.volume = this.isMuted ? 0 : this.masterVolume * 0.4;
    }
  },

  setVolume(value) {
    this.masterVolume = Math.max(0, Math.min(1, value));
    this.isMuted = this.masterVolume === 0;

    localStorage.setItem("pikaverse_volume", this.masterVolume.toString());

    this.applyVolumeToAll();
    this.updateAudioUI();
  },

  toggleMute() {
    this.isMuted = !this.isMuted;

    if (!this.isMuted && this.masterVolume === 0) {
      this.masterVolume = 0.5;
    }

    this.applyVolumeToAll();
    this.updateAudioUI();
  },

  loadVolume() {
    const stored = localStorage.getItem("pikaverse_volume");
    if (stored !== null) {
      const parsed = parseFloat(stored);
      if (!Number.isNaN(parsed)) {
        this.masterVolume = parsed;
      }
    }
    this.isMuted = this.masterVolume === 0;
    this.applyVolumeToAll();
  },

  updateAudioUI() {
    const slider = document.getElementById("audio-slider");
    const btn = document.getElementById("audio-mute");

    if (slider) {
      slider.value = String(this.masterVolume);
    }
    if (btn) {
      btn.textContent = this.isMuted ? "🔇" : "🔊";
    }
  },

  createAudioControls() {
    if (document.getElementById("audio-mute")) return;

    const container = document.createElement("div");
    container.style.position = "fixed";
