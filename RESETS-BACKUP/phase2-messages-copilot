          const idVal = t && typeof t === "object" ? (t.id || "") : "";

          div.innerHTML = `
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px;">

              <input placeholder="Label"
                     value="${labelVal}"
                     data-i="${i}"
                     class="p-label"
                     style="flex:1;" />

              <input placeholder="Node ID"
                     value="${idVal}"
                     data-i="${i}"
                     class="p-id"
                     style="width:120px;" />

              <button class="removeChoice"
                      data-i="${i}"
                      style="padding:2px 6px;font-size:12px;height:22px;">x</button>

            </div>
          `;
          list.appendChild(div);
        });
      }

      const addChoiceBtn = document.getElementById("addChoice");
      if (addChoiceBtn) {
        addChoiceBtn.onclick = () => {
          n.portalTargets = Array.isArray(n.portalTargets) ? n.portalTargets : [];
          n.portalTargets.push({ id: "", label: "" });
          this.render();
        };
      }

      const removeButtons = document.querySelectorAll(".removeChoice");
      removeButtons.forEach(btn => {
        btn.onclick = () => {
          const i = parseInt(btn.dataset.i, 10);
          if (!Array.isArray(n.portalTargets)) {
            n.portalTargets = [];
          }
          if (Number.isInteger(i) && i >= 0 && i < n.portalTargets.length) {
            n.portalTargets.splice(i, 1);
          }
          this.render();
        };
      });

      return;
    }

    if (n.type === "timer") {
      const seconds = typeof n.timerSeconds === "number" ? n.timerSeconds : 0;

      container.innerHTML = visualBlock + `
        <h4>Timer</h4>

        <label>Duration (seconds)</label><br/>
        <input id="timerSeconds" type="number" min="0" step="1" value="${seconds}" style="width:120px"/><br/><br/>

        <p style="font-size:12px;opacity:0.8;">
          When the timer reaches zero, the player will automatically advance to the Next Node (if set).
        </p>
      `;
      return;
    }

    if (n.type === "gem") {
      const defaults = [
        {
          label: "Ruby",
          gemId: "ruby",
          nextNodeId: "",
          consequence: { text: "", effect: "", sound: "", reward: "" }
        },
        {
          label: "Sapphire",
          gemId: "sapphire",
          nextNodeId: "",
          consequence: { text: "", effect: "", sound: "", reward: "" }
        },
        {
          label: "Emerald",
          gemId: "emerald",
          nextNodeId: "",
          consequence: { text: "", effect: "", sound: "", reward: "" }
        }
      ];

      const gemChoices = Array.isArray(n.gemChoices) && n.gemChoices.length === 3
        ? n.gemChoices
        : defaults;

      const gemBlock = (idx, gRaw) => {
        const g = gRaw && typeof gRaw === "object" ? gRaw : {};
        const consequence = g.consequence && typeof g.consequence === "object" ? g.consequence : {};

        const labelVal = g.label || "";
        const gemIdVal = g.gemId || "";
        const nextNodeIdVal = g.nextNodeId || "";
        const cTextVal = consequence.text || "";
        const cEffectVal = consequence.effect || "";
        const cSoundVal = consequence.sound || "";
        const cRewardVal = consequence.reward || "";

        return `
        <div style="border:1px solid #1f2230;padding:10px;border-radius:6px;margin-bottom:10px;">
          <h4>Gem ${idx + 1}</h4>

          <label>Label</label><br/>
          <input id="gem${idx}_label" value="${labelVal}" style="width:100%"/><br/><br/>

          <label>Gem ID</label><br/>
          <input id="gem${idx}_id" value="${gemIdVal}" style="width:100%"/><br/><br/>

          <label>Next Node ID</label><br/>
          <input id="gem${idx}_next" value="${nextNodeIdVal}" style="width:100%"/><br/><br/>

          <h5>Consequence</h5>

          <label>Consequence Text</label><br/>
          <textarea id="gem${idx}_c_text" style="width:100%">${cTextVal}</textarea><br/><br/>

          <label>Effect</label><br/>
          <input id="gem${idx}_c_effect" value="${cEffectVal}" style="width:100%"/><br/><br/>

          <label>Sound</label><br/>
          <input id="gem${idx}_c_sound" value="${cSoundVal}" style="width:100%"/><br/><br/>

          <label>Reward</label><br/>
          <input id="gem${idx}_c_reward" value="${cRewardVal}" style="width:100%"/><br/><br/>
        </div>
      `;
      };

      container.innerHTML =
        visualBlock +
        `<h4>Gem Choices (3 fixed)</h4>` +
        gemChoices.map((g, i) => gemBlock(i, g)).join("");

      return;
    }

    container.innerHTML = visualBlock + `<p>No special inputs required.</p>`;
  },

  save() {
    const n = this.node;
    if (!n) {
      console.warn("NodeEditor.save called without node");
      return;
    }

    const typeEl = document.getElementById("type");
    const titleEl = document.getElementById("title");
    const bodyEl = document.getElementById("body");
    const nextEl = document.getElementById("next");
    const bgImageEl = document.getElementById("bgImage");
    const textColorEl = document.getElementById("textColor");
    const accentColorEl = document.getElementById("accentColor");
    const fontFamilyEl = document.getElementById("fontFamily");
    const onEnterEl = document.getElementById("onEnter");
    const onExitEl = document.getElementById("onExit");

    if (!typeEl || !titleEl || !bodyEl || !nextEl || !bgImageEl || !textColorEl || !accentColorEl || !fontFamilyEl || !onEnterEl || !onExitEl) {
      console.warn("NodeEditor.save missing one or more core elements");
      return;
    }

    n.type = typeEl.value;
    n.title = titleEl.value;
    n.body = bodyEl.value;
    n.nextNodeId = nextEl.value || null;

    n.ui = n.ui && typeof n.ui === "object" ? n.ui : {};
    n.ui.backgroundImage = bgImageEl.value || "";
    n.ui.textColor = textColorEl.value || "#ffffff";
    n.ui.accentColor = accentColorEl.value || "#4f8cff";
    n.ui.fontFamily = fontFamilyEl.value || "Arial, sans-serif";

    n.onEnter = this.safeParse(onEnterEl.value);
    n.onExit = this.safeParse(onExitEl.value);

    if (!n.onEnter || typeof n.onEnter !== "object") n.onEnter = {};
    if (!n.onExit || typeof n.onExit !== "object") n.onExit = {};

    const rewardEnterEl = document.getElementById("adv_reward_enter");
    const rewardExitEl = document.getElementById("adv_reward_exit");
    const consumeEnterEl = document.getElementById("adv_consume_enter");
    const consumeExitEl = document.getElementById("adv_consume_exit");
    const requiresEl = document.getElementById("adv_requires");
    const failNodeIdEl = document.getElementById("adv_failNodeId");
    const conditionsEl = document.getElementById("adv_conditions");

    const rewardEnter = (rewardEnterEl?.value || "").trim();
    const rewardExit = (rewardExitEl?.value || "").trim();
    const consumeEnter = (consumeEnterEl?.value || "").trim();
    const consumeExit = (consumeExitEl?.value || "").trim();
    const requiresRaw = (requiresEl?.value || "").trim();
    const failNodeId = (failNodeIdEl?.value || "").trim();
    const conditionsRaw = conditionsEl ? conditionsEl.value || "" : "";

    if (rewardEnter) {
      n.onEnter.addToInventory = rewardEnter;
    } else if (n.onEnter.addToInventory) {
      delete n.onEnter.addToInventory;
    }

    if (rewardExit) {
      n.onExit.addToInventory = rewardExit;
    } else if (n.onExit.addToInventory) {
      delete n.onExit.addToInventory;
    }

    if (consumeEnter) {
      n.onEnter.removeFromInventory = consumeEnter;
    } else if (n.onEnter.removeFromInventory) {
      delete n.onEnter.removeFromInventory;
    }

    if (consumeExit) {
      n.onExit.removeFromInventory = consumeExit;
    } else if (n.onExit.removeFromInventory) {
      delete n.onExit.removeFromInventory;
    }

    if (requiresRaw) {
      n.requires = requiresRaw
        .split(",")
        .map(s => s.trim())
        .filter(Boolean);
    } else {
      n.requires = [];
    }

    n.failNodeId = failNodeId || null;

    const condParsed = this.safeParse(conditionsRaw);
    n.conditions = Array.isArray(condParsed) ? condParsed : [];

    if (n.type === "puzzle") {
      const promptEl = document.getElementById("prompt");
      const answerEl = document.getElementById("answer");
      const promptVal = promptEl ? promptEl.value : "";
      const answerVal = answerEl ? answerEl.value : "";

      n.puzzle = {
        puzzleType: "text",
        prompt: promptVal,
        answers: [answerVal]
      };
    } else {
      n.puzzle = null;
    }

    if (n.type === "wordPuzzle") {
      const wpPromptEl = document.getElementById("wp_prompt");
      const wpAnswerEl = document.getElementById("wp_answer");
      const wpPromptVal = wpPromptEl ? wpPromptEl.value : "";
      const wpAnswerVal = wpAnswerEl ? wpAnswerEl.value : "";

      n.wordPuzzle = {
        prompt: wpPromptVal,
        answers: [wpAnswerVal]
      };
    } else {
      n.wordPuzzle = null;
    }

    if (n.type === "portal") {
      const labels = document.querySelectorAll(".p-label");
      const ids = document.querySelectorAll(".p-id");

      const portalTargets = [];
      const maxLen = Math.max(labels.length, ids.length);

      for (let i = 0; i < maxLen; i++) {
        const labelEl = labels[i];
        const idEl = ids[i];
        if (!labelEl || !idEl) continue;
        portalTargets.push({
          label: labelEl.value,
          id: idEl.value
        });
      }

      n.portalTargets = portalTargets;
    } else {
      n.portalTargets = null;
    }

    if (n.type === "timer") {
      const timerEl = document.getElementById("timerSeconds");
      const raw = timerEl ? timerEl.value : "0";
      const parsed = parseInt(raw, 10);
      n.timerSeconds = Number.isFinite(parsed) && parsed >= 0 ? parsed : 0;
    } else {
      n.timerSeconds = 0;
    }

    if (n.type === "gem") {
      const readGem = (idx) => {
        const labelEl = document.getElementById(`gem${idx}_label`);
        const idEl = document.getElementById(`gem${idx}_id`);
        const nextEl = document.getElementById(`gem${idx}_next`);
        const cTextEl = document.getElementById(`gem${idx}_c_text`);
        const cEffectEl = document.getElementById(`gem${idx}_c_effect`);
        const cSoundEl = document.getElementById(`gem${idx}_c_sound`);
        const cRewardEl = document.getElementById(`gem${idx}_c_reward`);

        const label = labelEl ? labelEl.value : "";
        const gemId = idEl ? idEl.value : "";
        const nextNodeId = nextEl ? nextEl.value : "";

        const cText = cTextEl ? cTextEl.value : "";
        const cEffect = cEffectEl ? cEffectEl.value : "";
        const cSound = cSoundEl ? cSoundEl.value : "";
        const cReward = cRewardEl ? cRewardEl.value : "";

        return {
          label,
          gemId,
          nextNodeId,
          consequence: {
            text: cText,
            effect: cEffect,
            sound: cSound,
            reward: cReward
          }
        };
      };

      n.gemChoices = [0, 1, 2].map(readGem);
    } else {
      n.gemChoices = null;
    }

    const normalized = normalizeNode(n);
    if (this.onSave && typeof this.onSave === "function") {
      this.onSave(normalized);
    } else {
      console.warn("NodeEditor.onSave is not a function", this.onSave);
    }
  }
};

// LENIENT NORMALIZER
function normalizeNode(n) {
  if (!n || typeof n !== "object") return null;

  const base = { ...n };

  base.id = base.id ?? "";
  base.type = base.type || "story";
  base.title = base.title || "";
  base.body = base.body || "";
  base.nextNodeId = base.nextNodeId ?? null;

  const ui = base.ui && typeof base.ui === "object" ? { ...base.ui } : {};
  ui.backgroundImage = ui.backgroundImage || "";
  ui.textColor = ui.textColor || "#ffffff";
  ui.accentColor = ui.accentColor || "#4f8cff";
  ui.fontFamily = ui.fontFamily || "Arial, sans-serif";
  base.ui = ui;

  base.puzzle = base.puzzle ?? null;
  base.wordPuzzle = base.wordPuzzle ?? null;

  if (Array.isArray(base.portalTargets)) {
    base.portalTargets = base.portalTargets;
  } else if (base.portalTargets) {
    base.portalTargets = [base.portalTargets];
  } else {
    base.portalTargets = [];
  }

  base.timerSeconds =
    typeof base.timerSeconds === "number" ? base.timerSeconds : 0;

  if (Array.isArray(base.gemChoices)) {
    base.gemChoices = base.gemChoices;
  } else if (base.gemChoices) {
    base.gemChoices = [base.gemChoices];
  } else {
    base.gemChoices = [];
  }

  base.onEnter = base.onEnter && typeof base.onEnter === "object" ? base.onEnter : {};
  base.onExit = base.onExit && typeof base.onExit === "object" ? base.onExit : {};

  base.setState = base.setState ?? null;
  base.increment = base.increment ?? null;
  base.addToInventory = base.addToInventory ?? null;
  base.removeFromInventory = base.removeFromInventory ?? null;

  base.conditions = Array.isArray(base.conditions) ? base.conditions : [];
  base.requires = Array.isArray(base.requires) ? base.requires : [];
  base.failNodeId = base.failNodeId ?? null;

  return base;
}
