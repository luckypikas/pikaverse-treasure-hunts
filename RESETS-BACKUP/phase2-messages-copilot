    for (const cond of conditions) {
      if (!cond || typeof cond !== "object") continue;
      const key = cond.key;
      if (!key) continue;

      const value = this.getState(key);

      if ("equals" in cond && value !== cond.equals) return false;
      if ("notEquals" in cond && value === cond.notEquals) return false;

      if (typeof cond.gte === "number" && !(Number(value) >= cond.gte)) return false;
      if (typeof cond.lte === "number" && !(Number(value) <= cond.lte)) return false;
      if (typeof cond.gt === "number" && !(Number(value) > cond.gt)) return false;
      if (typeof cond.lt === "number" && !(Number(value) < cond.lt)) return false;
