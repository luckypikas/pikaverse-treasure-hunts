let hunts = [];
let results = [];
let selectedHunt = null;

// -----------------------------
// SAFE LOADERS
// -----------------------------
function safeParse(json, fallback) {
  try {
    const parsed = JSON.parse(json);
    return parsed && typeof parsed === "object" ? parsed : fallback;
  } catch {
    return fallback;
  }
}

// -----------------------------
// LOAD DATA
// -----------------------------
function loadData() {
  const h = localStorage.getItem("pikaverse_hunts");
  const r = localStorage.getItem("pikaverse_results");

  hunts = Array.isArray(safeParse(h, [])) ? safeParse(h, []) : [];
  results = Array.isArray(safeParse(r, [])) ? safeParse(r, []) : [];

  renderList();
}

// -----------------------------
// FIND BEST RESULT
// -----------------------------
function getBestResult(huntId) {
  if (!huntId) return null;

  const filtered = results.filter(r => r && r.huntId === huntId);
  if (filtered.length === 0) return null;

  return filtered.reduce((best, curr) => {
    const bestScore = best?.score?.totalScore || 0;
    const currScore = curr?.score?.totalScore || 0;
    return currScore > bestScore ? curr : best;
  }, filtered[0]);
}

// -----------------------------
// COMPLETION STATUS + ICON
// -----------------------------
function getCompletionStatus(huntId) {
  if (!huntId) {
    return {
      label: "● Not Started",
      className: "status-not-started"
    };
  }

  const attempts = results.filter(r => r && r.huntId === huntId).length;

  if (attempts > 0) {
    return {
      label: "✓ Completed",
      className: "status-completed"
    };
  }

  return {
    label: "● Not Started",
    className: "status-not-started"
  };
}

// -----------------------------
// LEFT LIST
// -----------------------------
function renderList() {
  const list = document.getElementById("hunt-list");
  if (!list) return;

  list.innerHTML = "";

  hunts.forEach(hunt => {
    if (!hunt || !hunt.id) return;

    const div = document.createElement("div");
    div.className = "hunt-item";

    const title = hunt.title || hunt.id || "Untitled Hunt";
    const difficulty = hunt.difficulty || "Standard";

    const status = getCompletionStatus(hunt.id);

    div.innerHTML = `
      <div><strong>${title}</strong></div>
      <div style="opacity:0.6;font-size:12px">${difficulty}</div>
      <div class="status-badge ${status.className}">
        ${status.label}
      </div>
    `;

    div.onclick = () => selectHunt(hunt);

    list.appendChild(div);
  });
}

// -----------------------------
// SELECT HUNT
// -----------------------------
function selectHunt(hunt) {
  if (!hunt) return;

  selectedHunt = hunt;

  document.querySelectorAll(".hunt-item")
    .forEach(el => el.classList.remove("active"));

  renderDetails(hunt);
}

// -----------------------------
// RIGHT PANEL
// -----------------------------
function renderDetails(hunt) {
  const container = document.getElementById("hunt-details");
  if (!container || !hunt) return;

  const best = getBestResult(hunt.id);
  const attempts = results.filter(r => r && r.huntId === hunt.id).length;

  const title = hunt.title || "Untitled Hunt";
  const description = hunt.description || "No description available.";
  const difficulty = hunt.difficulty || "Standard";

  const bestScore = best?.score?.totalScore || 0;
  const bestTime = best?.timeTaken != null ? best.timeTaken + "s" : "N/A";

  container.innerHTML = `
    <div class="detail-title">${title}</div>
    <div class="meta">${description}</div>

    <div class="stat">Difficulty: ${difficulty}</div>
    <div class="stat">Best Score: ${bestScore}</div>
    <div class="stat">Best Time: ${bestTime}</div>
    <div class="stat">Attempts: ${attempts}</div>

    <button class="start-btn" onclick="startHunt('${hunt.id}')">
      START HUNT
    </button>
  `;
}

// -----------------------------
// START HUNT
// -----------------------------
function startHunt(huntId) {
  if (!huntId) return;

  const hunt = hunts.find(h => h && h.id === huntId);
  if (!hunt) return;

  try {
    localStorage.setItem("pikaverse_hunt", JSON.stringify(hunt));
  } catch {
    // ignore storage errors
  }

  window.location.href = "game.html";
}

// -----------------------------
// INIT
// -----------------------------
loadData();
