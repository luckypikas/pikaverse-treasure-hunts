      const w = this.weights || {};

      const expectedTime =
        huntMeta &&
        typeof huntMeta.expectedTimeSeconds === "number" &&
        huntMeta.expectedTimeSeconds > 0
          ? huntMeta.expectedTimeSeconds
          : 300;

      const safeTime = Math.max(1, Number(timeTaken) || 0);
      const ratio = expectedTime / safeTime;
      const clampedRatio = Math.min(ratio, 3);
      const timeScore = Math.max(
        0,
